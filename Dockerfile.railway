###############################################################################
# Paperclip — all-in-one Railway container
# Bundles: Paperclip (Node + embedded Postgres) + Tailscale (userspace)
# Managed by supervisord. No TUN device required.
#
# Layer caching strategy:
#   - runtime: Tailscale + supervisor install (rarely changes)
#   - deps:    pnpm install from package.json files only (changes on dep bumps)
#   - build:   full source build (changes every push, but deps are cached)
#   - final:   copies from runtime + build, adds config (thin layer)
###############################################################################

# syntax=docker/dockerfile:1

# ── Stage 1: base ────────────────────────────────────────────────────────────
FROM node:lts-trixie-slim AS base
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git \
  && rm -rf /var/lib/apt/lists/*
RUN corepack enable

# ── Stage 2: runtime — Tailscale + supervisor (cached independently) ────────
FROM base AS runtime
RUN apt-get update \
  && apt-get install -y --no-install-recommends supervisor iptables \
  && curl -fsSL https://tailscale.com/install.sh | sh \
  && rm -rf /var/lib/apt/lists/*

# ── Stage 3: deps — install node_modules from lockfile only ─────────────────
FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY cli/package.json cli/
COPY server/package.json server/
COPY ui/package.json ui/
COPY packages/shared/package.json packages/shared/
COPY packages/db/package.json packages/db/
COPY packages/adapter-utils/package.json packages/adapter-utils/
COPY packages/adapters/claude-local/package.json packages/adapters/claude-local/
COPY packages/adapters/codex-local/package.json packages/adapters/codex-local/
COPY packages/adapters/cursor-local/package.json packages/adapters/cursor-local/
COPY packages/adapters/gemini-local/package.json packages/adapters/gemini-local/
COPY packages/adapters/openclaw-gateway/package.json packages/adapters/openclaw-gateway/
COPY packages/adapters/opencode-local/package.json packages/adapters/opencode-local/
COPY packages/adapters/pi-local/package.json packages/adapters/pi-local/
RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# ── Stage 4: build — full source copy, resolve remaining workspace pkgs ─────
FROM base AS build
WORKDIR /app
COPY --from=deps /app /app
COPY . .
RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --no-frozen-lockfile \
 && pnpm --filter @paperclipai/shared build \
 && pnpm --filter @paperclipai/plugin-sdk build \
 && pnpm --filter @paperclipai/ui build \
 && pnpm --filter @paperclipai/server build \
 && test -f server/dist/index.js || (echo "ERROR: server build output missing" && exit 1)

# ── Stage 5: final — assemble runtime + built app ──────────────────────────
FROM runtime AS final
WORKDIR /app

# Copy built app
COPY --from=build /app /app

# Create data directories
RUN mkdir -p /paperclip/instances/default \
  && mkdir -p /paperclip/tailscale \
  && mkdir -p /var/log/supervisor \
  && mkdir -p /etc/supervisor/conf.d \
  && mkdir -p /var/run/tailscale \
  && chown -R node:node /paperclip /app

# ── supervisord config ───────────────────────────────────────────────────────
COPY <<'EOF' /etc/supervisor/conf.d/supervisord.conf
[supervisord]
nodaemon=true
user=root
logfile=/var/log/supervisor/supervisord.log
logfile_maxbytes=10MB
pidfile=/var/run/supervisord.pid

[program:tailscaled]
command=/usr/sbin/tailscaled --tun=userspace-networking --statedir=/paperclip/tailscale --socket=/var/run/tailscale/tailscaled.sock
autostart=true
autorestart=true
priority=10
stdout_logfile=/dev/fd/1
stdout_logfile_maxbytes=0
stderr_logfile=/dev/fd/2
stderr_logfile_maxbytes=0

[program:tailscale-up]
command=/bin/sh -c "sleep 3 && /usr/bin/tailscale --socket=/var/run/tailscale/tailscaled.sock up --authkey=${TS_AUTHKEY} --hostname=${TS_HOSTNAME:-paperclip} --accept-routes && /usr/bin/tailscale --socket=/var/run/tailscale/tailscaled.sock serve --bg --https=443 http://127.0.0.1:3100"
autostart=true
autorestart=false
startsecs=0
priority=20
stdout_logfile=/dev/fd/1
stdout_logfile_maxbytes=0
stderr_logfile=/dev/fd/2
stderr_logfile_maxbytes=0

[program:paperclip]
command=node --import ./server/node_modules/tsx/dist/loader.mjs server/dist/index.js
directory=/app
user=node
autostart=true
autorestart=true
priority=30
stdout_logfile=/dev/fd/1
stdout_logfile_maxbytes=0
stderr_logfile=/dev/fd/2
stderr_logfile_maxbytes=0
environment=NODE_ENV="production",HOME="/paperclip",HOST="0.0.0.0",PORT="3100",SERVE_UI="true",PAPERCLIP_HOME="/paperclip",PAPERCLIP_INSTANCE_ID="default",PAPERCLIP_CONFIG="/paperclip/instances/default/config.json",PAPERCLIP_DEPLOYMENT_MODE="authenticated",PAPERCLIP_DEPLOYMENT_EXPOSURE="private"
EOF

# ── Entrypoint: fix volume ownership + clean bad state ───────────────────────
COPY <<'ENTRY' /usr/local/bin/entrypoint.sh
#!/bin/sh
# Fix volume ownership (Railway volumes mount as root)
chown -R node:node /paperclip

# Clean up corrupt/partial db init from prior failed boots
DB_DIR="/paperclip/instances/default/db"
if [ -d "$DB_DIR" ] && [ ! -f "$DB_DIR/PG_VERSION" ]; then
  echo "[entrypoint] Removing incomplete db directory: $DB_DIR"
  rm -rf "$DB_DIR"
fi

exec /usr/bin/supervisord -c /etc/supervisor/conf.d/supervisord.conf
ENTRY
RUN chmod +x /usr/local/bin/entrypoint.sh

EXPOSE 3100

CMD ["/usr/local/bin/entrypoint.sh"]
